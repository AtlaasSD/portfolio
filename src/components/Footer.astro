---
// Footer.astro — Terminal-style bar. Sleek, high-tech, closes the layout.
// GitHub corrected to: https://github.com/AtlaasSD

const YEAR    = new Date().getFullYear();
const GITHUB  = 'https://github.com/AtlaasSD';
const LI      = 'https://www.linkedin.com/in/brayan-su%C3%A1rez-ceballos/';
const EMAIL   = 'brasuce1@gmail.com';
---

<footer role="contentinfo" style="background: var(--surface); position: relative; z-index: 1;">

  <!-- Top separator: full-width rule with gradient -->
  <div style="height: 1px; background: linear-gradient(to right, transparent, rgba(59,130,246,0.4), rgba(139,92,246,0.4), transparent);"></div>

  <!-- Terminal bar -->
  <div style="
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  ">
    <!-- Main terminal line -->
    <div style="
      display: flex;
      align-items: center;
      gap: 0;
      height: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      overflow-x: auto;
      scrollbar-width: none;
    ">
      <!-- prompt -->
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #1e293b;
        white-space: nowrap;
        margin-right: 0.75rem;
        flex-shrink: 0;
      ">brayan@portfolio</span>
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #334155;
        margin-right: 0.25rem;
        flex-shrink: 0;
      ">:</span>
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #3b82f6;
        margin-right: 0.75rem;
        flex-shrink: 0;
      ">~</span>
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #475569;
        margin-right: 1rem;
        flex-shrink: 0;
      ">$</span>

      <!-- "command" -->
      <span style="
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #334155;
        white-space: nowrap;
        flex-shrink: 0;
      ">echo &quot;© {YEAR} Brayan Suárez Ceballos · Built with Astro · Deployed on Cloudflare Pages&quot;</span>

      <span class="cursor-blink" aria-hidden="true" style="margin-left: 0.25rem; flex-shrink: 0;"></span>
    </div>

    <!-- Second line: links -->
    <div style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      height: 3rem;
      flex-wrap: wrap;
    ">
      <!-- Left: tech stack credits -->
      <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
        {['Astro', 'Tailwind', 'TypeScript', 'Cloudflare'].map(t => (
          <span style="
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: #1e293b;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 0.125rem 0.5rem;
            border-radius: 2px;
          ">{t}</span>
        ))}
      </div>

      <!-- Right: social links (icon buttons) -->
      <nav aria-label="Social links" style="display: flex; align-items: center; gap: 0.25rem;">
        <a
          href={GITHUB}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub: AtlaasSD (opens in new tab)"
          id="footer-github"
          class="footer-icon-btn"
          style="
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            color: #334155;
            border-radius: 2px;
            transition: color 0.15s ease, background 0.15s ease;
            text-decoration: none;
          "
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <a
          href={LI}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn: Brayan Suárez Ceballos (opens in new tab)"
          id="footer-linkedin"
          class="footer-icon-btn"
          style="
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            color: #334155;
            border-radius: 2px;
            transition: color 0.15s ease, background 0.15s ease;
            text-decoration: none;
          "
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <a
          href={`https://mail.google.com/mail/?view=cm&fs=1&to=${EMAIL}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Send an email to Brayan"
          id="footer-email"
          class="footer-icon-btn"
          style="
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            color: #334155;
            border-radius: 2px;
            transition: color 0.15s ease, background 0.15s ease;
            text-decoration: none;
          "
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-icon-btn:hover {
    color: #3b82f6 !important;
    background: rgba(59,130,246,0.08) !important;
  }
</style>
